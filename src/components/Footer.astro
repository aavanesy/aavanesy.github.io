---
const currentYear = new Date().getFullYear();

const socialLinks = [
  {
    href: "https://www.linkedin.com/in/arkadiavan/",
    label: "LinkedIn",
  },
  {
    href: "https://github.com/aavanesy",
    label: "GitHub",
  },
  {
    href: "mailto:aavanesy@outlook.com",
    label: "Email",
  },
];
---

<footer class="dark-section border-t border-bg-dark-border">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="flex flex-col md:flex-row justify-between items-center gap-8">
      <div class="text-center md:text-left">
        <p class="font-serif italic text-white text-lg mb-1">A. Avanesyan</p>
        <p class="text-xs text-[#6B5D4F] tracking-widest uppercase">Quantitative Finance & Data Science</p>
      </div>

      <div class="flex items-center gap-8">
        {socialLinks.map((link) => (
          <a
            href={link.href}
            class="text-xs text-[#8A7D6B] hover:text-accent transition-colors uppercase tracking-widest"
            {...(link.href.startsWith("mailto:") ? {} : { target: "_blank", rel: "noopener noreferrer" })}
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-bg-dark-border text-center">
      <p class="text-xs text-[#6B5D4F] tracking-wide">&copy; {currentYear} Arkadi Avanesyan</p>
    </div>
  </div>
</footer>
