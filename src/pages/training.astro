---
import Layout from "../layouts/Layout.astro";

const expertise = [
  {
    title: "Excel & VBA for Analytics",
    period: "Since 2008",
    description: "Data analysis, reporting, and financial modeling in Excel and VBA.",
  },
  {
    title: "Investment Banking: Quantitative Development",
    period: "2012\u20132019",
    description: "Built and rebalanced proprietary investable indices for Societe Generale, Deutsche Bank, Goldman Sachs, and BNP Paribas.",
  },
  {
    title: "Data Science",
    period: "Since 2018",
    description: "Python and R for statistical analysis, machine learning, and data visualization.",
  },
  {
    title: "R for Automation",
    period: "Since 2014",
    description: "Data manipulation, process optimization, and workflow automation in R.",
  },
  {
    title: "Microsoft Power Automate",
    period: "Since 2020",
    description: "No-code business process automation for teams where coding is not practical.",
  },
];

const clients = [
  {
    year: "2023",
    company: "HSBC",
    description: "Trained teams remotely in advanced analytics and robotic process automation for the Banking & Financial Services program.",
  },
  {
    year: "2022",
    company: "The World Bank",
    description: "Trained multiple teams in data science, Excel, R, and SQL.",
  },
  {
    year: "2021\u20132022",
    company: "Aigora",
    description: "Ran workshops on automation and data science reporting for teams in the US and Europe.",
  },
];
---

<Layout title="Corporate Training | Arkadi Avanesyan">
  <!-- Hero -->
  <section class="pt-32 pb-16 px-6">
    <div class="max-w-4xl mx-auto">
      <p class="text-accent tracking-[0.3em] text-xs mb-6 uppercase">For teams</p>
      <h1 class="text-4xl lg:text-6xl font-bold text-text-primary mb-8 leading-tight">
        Corporate Training
      </h1>
      <p class="text-xl text-text-secondary max-w-2xl leading-relaxed">
        I train teams in finance, data science, and automation. Custom programs built around your team's specific needs.
      </p>
    </div>
  </section>

  <!-- Expertise -->
  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <span class="font-serif italic text-accent text-sm">01</span>
      <h2 class="text-3xl lg:text-4xl font-bold text-text-primary mt-3 mb-16">What I teach</h2>

      <div class="space-y-0 divide-y divide-border">
        {expertise.map((item) => (
          <div class="py-8 first:pt-0">
            <div class="flex flex-col md:flex-row md:items-baseline gap-2 md:gap-8 mb-3">
              <h3 class="font-semibold text-text-primary text-lg flex-1">{item.title}</h3>
              <span class="text-xs text-text-muted tracking-widest uppercase">{item.period}</span>
            </div>
            <p class="text-text-secondary text-sm max-w-2xl leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Clients -->
  <section class="green-section py-24 px-6">
    <div class="max-w-4xl mx-auto">
      <span class="font-serif italic text-accent text-sm">02</span>
      <h2 class="text-3xl lg:text-4xl font-bold mt-3 mb-16">Notable Clients</h2>

      <div class="space-y-12">
        {clients.map((client) => (
          <div>
            <p class="text-[#8BAE90] text-xs uppercase tracking-widest mb-2">{client.year}</p>
            <h3 class="font-serif font-bold text-3xl text-[#E8F0EA] mb-3">{client.company}</h3>
            <p class="text-[#C5D5C8] max-w-xl leading-relaxed">{client.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-32 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl lg:text-4xl font-bold text-text-primary mb-6">Train your team</h2>
      <p class="text-text-secondary text-lg mb-12 max-w-lg mx-auto">
        Email me to start a conversation about your team's needs.
      </p>
      <a href="mailto:aavanesy@outlook.com" class="btn-primary">Get in Touch</a>
    </div>
  </section>
</Layout>
