---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Arkadi Avanesyan | Finance, Data Science & Technology">
  <!-- Hero - full viewport, dark textured -->
  <section class="relative min-h-screen flex items-center px-6 dark-section overflow-hidden">
    <div class="relative max-w-6xl mx-auto w-full py-24">
      <div class="flex flex-col lg:flex-row items-center lg:items-center gap-16 lg:gap-24">
        <!-- Portrait -->
        <div class="flex-shrink-0">
          <div class="relative">
            <div class="absolute -inset-3 border border-accent/20"></div>
            <img
              src="/head_shot.png"
              alt="Arkadi Avanesyan"
              width="320"
              height="320"
              fetchpriority="high"
              decoding="async"
              class="w-60 h-60 lg:w-80 lg:h-80 object-cover grayscale-[20%]"
            />
          </div>
        </div>

        <!-- Content -->
        <div class="text-center lg:text-left flex-1">
          <p class="text-accent tracking-[0.3em] text-xs mb-8 uppercase">Quantitative Finance</p>
          <h1 class="text-5xl lg:text-7xl xl:text-8xl font-bold text-white mb-8 leading-[0.9] tracking-tight">
            Arkadi<br /> Avanesyan
          </h1>
          <div class="w-12 h-px bg-accent mb-8 mx-auto lg:mx-0"></div>
          <p class="text-lg text-[#D5C9B8] mb-6 max-w-lg leading-relaxed">
            10+ years building institutional investment products. My indices were commercialized by Societe Generale across 60+ countries and used by Goldman Sachs and Deutsche Bank in structured products worth over &euro;1.5 billion.
          </p>
          <p class="text-sm text-[#8A7D6B] mb-12 max-w-lg">
            MSc Quantitative Finance, Solvay Brussels School<br />
            BSc Business Engineering, Free University of Brussels
          </p>
          <div class="flex flex-wrap gap-5 justify-center lg:justify-start">
            <a href="/courses" class="btn-primary">Browse Courses</a>
            <a href="mailto:aavanesy@outlook.com" class="text-sm text-[#9A8B78] hover:text-accent transition-colors underline underline-offset-4 decoration-[#9A8B78]/30 hover:decoration-accent/50 py-3">
              Contact
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Credibility band - green textured -->
  <section class="green-section py-10 px-6">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
      <p class="tracking-[0.25em] text-xs uppercase text-[#8BAE90]">
        Societe Generale &middot; Goldman Sachs &middot; Deutsche Bank &middot; HSBC &middot; World Bank
      </p>
      <p class="text-sm text-[#C5D5C8] font-serif italic">80,000+ students taught worldwide</p>
    </div>
  </section>

  <!-- Courses - editorial -->
  <section class="py-32 px-6">
    <div class="max-w-4xl mx-auto">
      <span class="font-serif italic text-accent text-sm">01</span>
      <h2 class="text-4xl lg:text-5xl font-bold text-text-primary mt-3 mb-16 leading-tight">Courses</h2>

      <div class="space-y-16">
        <a href="https://www.coursera.org/instructor/~139312072" target="_blank" rel="noopener noreferrer" class="group block">
          <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-3">
            <div>
              <p class="text-text-muted text-xs uppercase tracking-widest mb-2">Coursera</p>
              <p class="text-5xl lg:text-6xl font-serif font-bold text-text-primary group-hover:text-accent transition-colors">70,000+</p>
            </div>
            <span class="text-accent text-sm font-medium opacity-0 group-hover:opacity-100 transition-opacity pb-2">
              View courses &rarr;
            </span>
          </div>
          <p class="text-text-secondary max-w-md">Quantitative finance and data science courses for professionals and students.</p>
          <div class="w-full h-px bg-border mt-8"></div>
        </a>

        <a href="https://www.udemy.com/user/arkadi-10/" target="_blank" rel="noopener noreferrer" class="group block">
          <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-3">
            <div>
              <p class="text-text-muted text-xs uppercase tracking-widest mb-2">Udemy</p>
              <p class="text-5xl lg:text-6xl font-serif font-bold text-text-primary group-hover:text-accent transition-colors">8,000+</p>
            </div>
            <span class="text-accent text-sm font-medium opacity-0 group-hover:opacity-100 transition-opacity pb-2">
              View courses &rarr;
            </span>
          </div>
          <p class="text-text-secondary max-w-md">R programming, automation, and productivity for working professionals.</p>
          <div class="w-full h-px bg-border mt-8"></div>
        </a>
      </div>
    </div>
  </section>

  <!-- Training preview - green accent -->
  <section class="green-section py-24 px-6">
    <div class="max-w-4xl mx-auto">
      <span class="font-serif italic text-accent text-sm">02</span>
      <h2 class="text-4xl lg:text-5xl font-bold mt-3 mb-8 leading-tight">Corporate Training</h2>
      <p class="text-lg text-[#C5D5C8] max-w-2xl mb-12 leading-relaxed">
        I've trained teams at HSBC, The World Bank, and Aigora in analytics, data science, and automation. I build custom programs around your team's specific needs.
      </p>
      <a href="/training" class="text-sm text-accent hover:text-accent-light transition-colors underline underline-offset-4 decoration-accent/30 hover:decoration-accent">
        Learn about training &rarr;
      </a>
    </div>
  </section>

  <!-- Resources preview -->
  <section class="py-32 px-6">
    <div class="max-w-4xl mx-auto">
      <span class="font-serif italic text-accent text-sm">03</span>
      <h2 class="text-4xl lg:text-5xl font-bold text-text-primary mt-3 mb-16 leading-tight">Resources</h2>

      <div class="grid md:grid-cols-2 gap-12">
        <a href="/quant-r" class="group block">
          <p class="text-text-muted text-xs uppercase tracking-widest mb-3">Free Series</p>
          <h3 class="text-2xl font-bold text-text-primary group-hover:text-accent transition-colors mb-3">Quant R</h3>
          <p class="text-text-secondary text-sm leading-relaxed">Investing truths verified with R code. Concept-first lessons that prove what Wall Street won't tell you.</p>
        </a>

        <a href="/tutorials" class="group block">
          <p class="text-text-muted text-xs uppercase tracking-widest mb-3">Tutorial</p>
          <h3 class="text-2xl font-bold text-text-primary group-hover:text-accent transition-colors mb-3">S&P 500 Drawdowns</h3>
          <p class="text-text-secondary text-sm leading-relaxed">Use PerformanceAnalytics in R to identify every major market crash since 1990.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="green-section py-32 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-accent tracking-[0.3em] text-xs mb-6 uppercase">Get started</p>
      <h2 class="text-4xl lg:text-5xl font-bold mb-6 leading-tight">Start learning</h2>
      <p class="text-[#8BAE90] text-lg mb-12 max-w-lg mx-auto">
        Explore my courses or get in touch about corporate training.
      </p>
      <div class="flex flex-wrap gap-5 justify-center">
        <a href="/courses" class="btn-primary">Browse Courses</a>
        <a href="/training" class="text-sm text-[#8BAE90] hover:text-accent transition-colors underline underline-offset-4 decoration-[#8BAE90]/30 hover:decoration-accent/50 py-3">
          Corporate Training
        </a>
      </div>
    </div>
  </section>
</Layout>
