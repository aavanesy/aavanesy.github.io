---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Arkadi Avanesyan | Finance, Data Science & Technology">
  <!-- Hero Section -->
  <section class="pt-32 pb-6 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
        <!-- Profile Image -->
        <div class="flex-shrink-0">
          <div class="relative">
            <div class="absolute inset-0 bg-gradient-to-br from-red-500 to-red-400 rounded-2xl blur-2xl opacity-20 scale-110"></div>
            <img
              src="/Arkadi2.jpg"
              alt="Arkadi Avanesyan"
              class="relative w-64 h-80 lg:w-80 lg:h-96 rounded-2xl object-cover object-top shadow-2xl ring-4 ring-white"
            />
          </div>
        </div>

        <!-- Hero Content -->
        <div class="text-center lg:text-left">
          <h1 class="text-4xl lg:text-5xl font-bold text-slate-900 mb-4">
            Hi, I'm <span class="gradient-text">Arkadi Avanesyan</span>
          </h1>
          <p class="text-xl text-slate-600 mb-4 max-w-2xl">
            Quant Developer and Educator in Finance, Data Science, and Technology.
          </p>
          <p class="text-lg text-slate-500 mb-4 max-w-2xl">
            10+ years building institutional investment products. My work was commercialized by Societe Generale across 60+ countries and used by Goldman Sachs and Deutsche Bank in structured products worth over €1.5 billion.
          </p>
          <p class="text-sm text-slate-400 mb-6 max-w-2xl">
            MSc Quantitative Finance, Solvay Brussels School | BSc Business Engineering, Free University of Brussels
          </p>
          <div class="flex flex-wrap gap-4 justify-center lg:justify-start items-center">
            <a href="mailto:aavanesy@outlook.com" class="btn-primary">
              Contact Me
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What I Do -->
  <section class="py-6 px-6 bg-white">
    <div class="max-w-4xl mx-auto">
      <div class="grid md:grid-cols-3 gap-6">
        <a href="/courses" class="card group">
          <h3 class="font-semibold text-slate-900 mb-2">Online Courses</h3>
          <p class="text-slate-500 text-sm mb-4">Quantitative finance, data science, and automation on Coursera, Udemy, and Codementor.</p>
          <span class="text-red-600 text-sm flex items-center gap-1 group-hover:gap-2 transition-all">
            Explore
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </span>
        </a>
        <a href="/training" class="card group">
          <h3 class="font-semibold text-slate-900 mb-2">Corporate Training</h3>
          <p class="text-slate-500 text-sm mb-4">Custom programs for teams in Excel, VBA, data science, R, and process automation.</p>
          <span class="text-red-600 text-sm flex items-center gap-1 group-hover:gap-2 transition-all">
            Explore
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </span>
        </a>
        <a href="/ai-for-finance" class="card group">
          <h3 class="font-semibold text-slate-900 mb-2">AI for Finance</h3>
          <p class="text-slate-500 text-sm mb-4">AI agents and automation for market analysis, portfolio management, and reporting.</p>
          <span class="text-red-600 text-sm flex items-center gap-1 group-hover:gap-2 transition-all">
            Explore
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </span>
        </a>
      </div>
    </div>
  </section>

</Layout>
