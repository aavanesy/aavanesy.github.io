---
import Layout from "../layouts/Layout.astro";

const tutorials = [
  {
    href: "/tutorials#sp500-drawdowns",
    title: "Analyzing S&P 500 Drawdowns with R",
  },
];

const resources = [
  {
    href: "/stress-test",
    title: "2026 Portfolio Stress-Test",
    active: true,
  },
];
---

<Layout title="2026 Portfolio Stress-Test | Arkadi Avanesyan" description="Free checklist to identify hidden risks in your portfolio before the next market crash.">
  <section class="pt-32 pb-6 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col lg:flex-row gap-8">
        <!-- Sidebar -->
        <aside class="lg:w-64 flex-shrink-0 lg:sticky lg:top-24 lg:self-start space-y-6">
          <!-- Tutorials Nav -->
          <div>
            <h2 class="text-sm font-semibold text-text-muted uppercase tracking-wide mb-4">Tutorials</h2>
            <nav class="space-y-2">
              {tutorials.map((tutorial) => (
                <a
                  href={tutorial.href}
                  class="block px-4 py-3 rounded-sm bg-bg-warm border border-border text-text-primary font-medium"
                >
                  {tutorial.title}
                </a>
              ))}
            </nav>
          </div>

          <!-- Resources Nav -->
          <div>
            <h2 class="text-sm font-semibold text-text-muted uppercase tracking-wide mb-4">Resources</h2>
            <nav class="space-y-2">
              {resources.map((resource) => (
                <a
                  href={resource.href}
                  class:list={[
                    "block px-4 py-3 rounded-sm font-medium",
                    resource.active
                      ? "bg-bg-subtle border border-border text-text-primary"
                      : "bg-bg-warm border border-border text-text-primary"
                  ]}
                >
                  {resource.title}
                </a>
              ))}
            </nav>
          </div>
        </aside>

        <!-- Main Content -->
        <div class="flex-1">
          <!-- Stress Test Content -->
          <article class="card">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-8 h-8 rounded-sm bg-red-100 flex items-center justify-center">
                <svg class="w-4 h-4 text-red-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              </div>
              <div>
                <span class="text-sm text-red-700 font-medium">Free Checklist</span>
                <h1 class="text-2xl font-bold text-text-primary">Is Your Portfolio Ready for a 20% Drop?</h1>
              </div>
            </div>

            <p class="text-text-secondary mb-6">
              Most investors don't realize their portfolio is "fragile" until a crash has already started. The S&P 500 experiences drawdowns exceeding 20% roughly once every 5-7 years. Use this checklist to stress-test your holdings today.
            </p>

            <!-- Checklist Section 1 -->
            <div class="mb-8">
              <h3 class="text-lg font-semibold text-text-primary mb-3">1. Concentration Risk</h3>
              <p class="text-text-secondary mb-3">
                Over-concentration in single positions or sectors amplifies losses during corrections:
              </p>
              <div class="bg-bg-warm rounded-sm p-4 space-y-3">
                <label class="flex items-start gap-3 cursor-pointer">
                  <input type="checkbox" class="mt-1 w-4 h-4 rounded-sm border-border text-accent focus:ring-accent" />
                  <span class="text-text-secondary">No single position exceeds 10% of my portfolio</span>
                </label>
                <label class="flex items-start gap-3 cursor-pointer">
                  <input type="checkbox" class="mt-1 w-4 h-4 rounded-sm border-border text-accent focus:ring-accent" />
                  <span class="text-text-secondary">No single sector exceeds 25% of my portfolio</span>
                </label>
                <label class="flex items-start gap-3 cursor-pointer">
                  <input type="checkbox" class="mt-1 w-4 h-4 rounded-sm border-border text-accent focus:ring-accent" />
                  <span class="text-text-secondary">I have exposure to at least 3 uncorrelated asset classes</span>
                </label>
              </div>
            </div>

            <!-- Checklist Section 2 -->
            <div class="mb-8">
              <h3 class="text-lg font-semibold text-text-primary mb-3">2. Liquidity Risk</h3>
              <p class="text-text-secondary mb-3">
                Illiquid positions become traps when you need to raise cash quickly:
              </p>
              <div class="bg-bg-warm rounded-sm p-4 space-y-3">
                <label class="flex items-start gap-3 cursor-pointer">
                  <input type="checkbox" class="mt-1 w-4 h-4 rounded-sm border-border text-accent focus:ring-accent" />
                  <span class="text-text-secondary">I can liquidate 80% of my portfolio within 24 hours</span>
                </label>
                <label class="flex items-start gap-3 cursor-pointer">
                  <input type="checkbox" class="mt-1 w-4 h-4 rounded-sm border-border text-accent focus:ring-accent" />
                  <span class="text-text-secondary">I have 3-6 months of expenses in cash or equivalents</span>
                </label>
                <label class="flex items-start gap-3 cursor-pointer">
                  <input type="checkbox" class="mt-1 w-4 h-4 rounded-sm border-border text-accent focus:ring-accent" />
                  <span class="text-text-secondary">I don't hold illiquid assets I might need to sell in a downturn</span>
                </label>
              </div>
            </div>

            <!-- Checklist Section 3 -->
            <div class="mb-8">
              <h3 class="text-lg font-semibold text-text-primary mb-3">3. Behavioral Risk</h3>
              <p class="text-text-secondary mb-3">
                Panic-selling at the bottom destroys more wealth than the crashes themselves:
              </p>
              <div class="bg-bg-warm rounded-sm p-4 space-y-3">
                <label class="flex items-start gap-3 cursor-pointer">
                  <input type="checkbox" class="mt-1 w-4 h-4 rounded-sm border-border text-accent focus:ring-accent" />
                  <span class="text-text-secondary">I can watch my portfolio drop 30% without panic-selling</span>
                </label>
                <label class="flex items-start gap-3 cursor-pointer">
                  <input type="checkbox" class="mt-1 w-4 h-4 rounded-sm border-border text-accent focus:ring-accent" />
                  <span class="text-text-secondary">I have a written plan for what to do in a market crash</span>
                </label>
                <label class="flex items-start gap-3 cursor-pointer">
                  <input type="checkbox" class="mt-1 w-4 h-4 rounded-sm border-border text-accent focus:ring-accent" />
                  <span class="text-text-secondary">I have cash reserved specifically to buy during crashes</span>
                </label>
              </div>
            </div>

            <!-- Checklist Section 4 -->
            <div class="mb-8">
              <h3 class="text-lg font-semibold text-text-primary mb-3">4. Structural Risk</h3>
              <p class="text-text-secondary mb-3">
                Portfolio structure determines whether you survive or thrive in volatility:
              </p>
              <div class="bg-bg-warm rounded-sm p-4 space-y-3">
                <label class="flex items-start gap-3 cursor-pointer">
                  <input type="checkbox" class="mt-1 w-4 h-4 rounded-sm border-border text-accent focus:ring-accent" />
                  <span class="text-text-secondary">I understand the beta of each position relative to the market</span>
                </label>
                <label class="flex items-start gap-3 cursor-pointer">
                  <input type="checkbox" class="mt-1 w-4 h-4 rounded-sm border-border text-accent focus:ring-accent" />
                  <span class="text-text-secondary">I have at least one "antifragile" position that benefits from volatility</span>
                </label>
                <label class="flex items-start gap-3 cursor-pointer">
                  <input type="checkbox" class="mt-1 w-4 h-4 rounded-sm border-border text-accent focus:ring-accent" />
                  <span class="text-text-secondary">My portfolio's maximum drawdown in 2008/2020 scenarios is acceptable to me</span>
                </label>
              </div>
            </div>

            <!-- Score Section -->
            <div class="mb-8">
              <h3 class="text-lg font-semibold text-text-primary mb-3">5. Interpret your results</h3>
              <p class="text-text-secondary mb-3">
                Count how many items you checked to assess your portfolio's resilience:
              </p>
              <div class="bg-bg-warm rounded-sm p-4 space-y-2 text-sm">
                <p class="text-text-secondary"><span class="font-semibold text-green-700">10-12 checks:</span> Your portfolio is well-prepared for market stress.</p>
                <p class="text-text-secondary"><span class="font-semibold text-amber-700">6-9 checks:</span> You have some vulnerabilities that could cause problems.</p>
                <p class="text-text-secondary"><span class="font-semibold text-red-700">0-5 checks:</span> Your portfolio may be more fragile than you think.</p>
              </div>
            </div>

            <!-- Key Insight -->
            <div class="border-t border-border pt-6 mt-8">
              <p class="text-text-secondary mb-6">
                <strong>Key insight:</strong> Most portfolios are designed to grow in bull markets, not survive bear markets. The items you couldn't check represent the structural flaws that cause panic-selling when crashes happen. This is the foundation of antifragile portfolio construction.
              </p>
            </div>
          </article>

        </div>
      </div>
    </div>
  </section>

  <!-- More Resources -->
  <section class="py-12 px-6">
    <div class="max-w-6xl mx-auto text-center">
      <p class="text-text-secondary mb-4">
        Learn the quantitative methods behind this checklist.
      </p>
      <a href="/tutorials" class="btn-secondary">
        See the R Tutorial
      </a>
    </div>
  </section>
</Layout>
