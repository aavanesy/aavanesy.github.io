        <!-- Main Content -->
        <div class="flex-1">
          <!-- Page Header -->
          <div class="mb-8">
            <div class="flex items-center gap-2 mb-2">
              <span class="px-2 py-1 bg-emerald-100 text-emerald-700 text-xs font-medium rounded">R + Finance</span>
              <span class="text-slate-400 text-sm">New lessons daily</span>
            </div>
            <h1 class="text-3xl font-bold text-slate-900 mb-2">Quant R: Investing Truths Verified with Code</h1>
            <p class="text-slate-600">
              Every lesson answers ONE investing question that keeps people up at night. The R code PROVES the answer is true.
            </p>
          </div>

          <!-- Lesson 01 Content -->
          <article id="average-returns-lie" data-lesson="average-returns-lie" class="lesson-content hidden card border-l-4 border-l-emerald-500">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-12 h-12 rounded-xl bg-emerald-100 flex items-center justify-center">
                <span class="text-emerald-600 font-bold text-lg">01</span>
              </div>
              <div>
                <span class="text-sm text-emerald-600 font-medium">Lesson 01</span>
                <h2 class="text-2xl font-bold text-slate-900">Why "Average Returns" Are a Lie</h2>
              </div>
            </div>

            <!-- The Hook -->
            <div class="bg-slate-900 text-white rounded-xl p-6 mb-8">
              <p class="text-xl font-medium mb-2">Your broker says you earned 0% last year.</p>
              <p class="text-xl font-medium text-emerald-400">You actually LOST 25%.</p>
            </div>

            <!-- The Concept -->
            <div class="mb-8">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">The Concept</h3>
              <p class="text-slate-600 mb-4">
                Wall Street reports "average returns" because it sounds better than reality. If you gain 50% then lose 50%, your <strong>AVERAGE</strong> return is 0%. But your <strong>ACTUAL</strong> return is -25%.
              </p>
              <p class="text-slate-600">
                This isn't a rounding error — it's the difference between retiring comfortably and running out of money.
              </p>
            </div>

            <!-- The Math Example -->
            <div class="mb-8 bg-slate-50 rounded-xl p-6">
              <h3 class="text-lg font-semibold text-slate-900 mb-4">The Math They Don't Show You</h3>
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <p class="text-sm text-slate-500 mb-2">What your broker reports:</p>
                  <ul class="space-y-1 text-slate-700">
                    <li>Year 1: <span class="text-emerald-600 font-medium">+50%</span></li>
                    <li>Year 2: <span class="text-red-600 font-medium">-50%</span></li>
                    <li class="pt-2 border-t border-slate-200 font-semibold">Average: 0%</li>
                  </ul>
                </div>
                <div>
                  <p class="text-sm text-slate-500 mb-2">What actually happened:</p>
                  <ul class="space-y-1 text-slate-700">
                    <li>Start: $100</li>
                    <li>After Year 1: $150</li>
                    <li>After Year 2: $75</li>
                    <li class="pt-2 border-t border-slate-200 font-semibold text-red-600">You lost $25 on a "zero percent return"</li>
                  </ul>
                </div>
              </div>
            </div>

            <!-- What the R Code Proves -->
            <div class="mb-8">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">What the R Code Proves</h3>
              <ul class="space-y-2 text-slate-600">
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-emerald-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                  <span>Generate returns that average 0% but produce negative wealth</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-emerald-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                  <span>Show the gap between arithmetic mean and geometric mean</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-emerald-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                  <span>Demonstrate the "volatility tax" — how swings destroy wealth</span>
                </li>
              </ul>
            </div>

            <!-- The R Code -->
            <div class="mb-8">
              <h3 class="text-lg font-semibold text-slate-900 mb-3">The R Code</h3>
              <pre class="bg-slate-900 text-slate-100 rounded-xl p-4 overflow-x-auto text-sm"><code># The volatility lie - Lesson 01
# Why "Average Returns" Are a Lie

# Simple example: +50% then -50%
returns <- c(0.50, -0.50)

# What your broker reports (arithmetic mean)
arithmetic_mean <- mean(returns)
cat("Reported 'Average' Return:", arithmetic_mean * 100, "%\n")

# What actually happened (geometric return)
actual_result <- prod(1 + returns) - 1
cat("Actual Return:", actual_result * 100, "%\n")

# Let's see it with real money
initial_investment <- 100
after_year_1 <- initial_investment * (1 + returns[1])
after_year_2 <- after_year_1 * (1 + returns[2])

cat("\nStarting amount: $", initial_investment, "\n")
cat("After Year 1 (+50%): $", after_year_1, "\n")
cat("After Year 2 (-50%): $", after_year_2, "\n")
cat("You LOST: $", initial_investment - after_year_2, "\n")

# The volatility tax over time
set.seed(42)
years <- 20
volatile_returns <- rnorm(years, mean = 0.08, sd = 0.25)  # 8% avg, 25% vol
steady_returns <- rep(0.04, years)  # 4% steady

volatile_wealth <- 10000 * cumprod(1 + volatile_returns)
steady_wealth <- 10000 * cumprod(1 + steady_returns)

cat("\n--- After", years, "years ---\n")
cat("Volatile portfolio (8% avg, 25% vol): $", round(tail(volatile_wealth, 1)), "\n")
cat("Steady portfolio (4% steady): $", round(tail(steady_wealth, 1)), "\n")</code></pre>
            </div>

            <!-- Key Takeaway -->
            <div class="bg-emerald-50 border border-emerald-200 rounded-xl p-6 mb-8">
              <h3 class="text-lg font-semibold text-emerald-800 mb-2">Key Takeaway</h3>
              <p class="text-emerald-700">
                <strong>Ask for GEOMETRIC returns, not averages.</strong> The arithmetic mean lies to you. The geometric mean tells you what you actually keep.
              </p>
            </div>

            <!-- Download -->
            <div class="border-t border-slate-200 pt-6">
              <a
                href="/files/quant-r-lesson-01.R"
