  <script>
    function showLesson(slug: string) {
      // Hide all lessons
      document.querySelectorAll('.lesson-content').forEach(el => {
        el.classList.add('hidden');
      });

      // Show selected lesson
      const lesson = document.querySelector(`[data-lesson="${slug}"]`);
      if (lesson) {
        lesson.classList.remove('hidden');
      }

      // Update sidebar active state
      document.querySelectorAll('.lesson-link').forEach(el => {
        el.classList.remove('bg-emerald-50', 'border-emerald-100');
        el.classList.add('bg-white', 'border-slate-200');
      });
      const activeLink = document.querySelector(`[data-lesson-link="${slug}"]`);
      if (activeLink) {
        activeLink.classList.remove('bg-white', 'border-slate-200');
        activeLink.classList.add('bg-emerald-50', 'border-emerald-100');
      }

      // Update download links
      document.getElementById('download-link-01')?.classList.add('hidden');
      document.getElementById('download-link-01')?.classList.remove('flex');
      document.getElementById('download-link-05')?.classList.add('hidden');
      document.getElementById('download-link-05')?.classList.remove('flex');

      if (slug === 'average-returns-lie') {
        document.getElementById('download-link-01')?.classList.remove('hidden');
        document.getElementById('download-link-01')?.classList.add('flex');
      } else if (slug === 'dubai-drop') {
        document.getElementById('download-link-05')?.classList.remove('hidden');
        document.getElementById('download-link-05')?.classList.add('flex');
      }
    }

    // Handle hash change
    function handleHash() {
      const hash = window.location.hash.slice(1) || 'average-returns-lie';
      showLesson(hash);
    }

    // Initialize
    handleHash();
    window.addEventListener('hashchange', handleHash);
  </script>
</Layout>
