---
import Layout from "../layouts/Layout.astro";
---

<Layout title="About | Arkadi Avanesyan">
  <!-- Hero -->
  <section class="pt-32 pb-16 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
        <!-- Profile Image -->
        <div class="flex-shrink-0">
          <div class="relative">
            <div class="absolute inset-0 bg-gradient-to-br from-blue-500 to-cyan-400 rounded-3xl blur-2xl opacity-20 scale-110"></div>
            <img
              src="/Arkadi.jpg"
              alt="Arkadi Avanesyan"
              class="relative w-72 h-72 lg:w-96 lg:h-96 rounded-3xl object-cover shadow-2xl"
            />
          </div>
        </div>

        <!-- Content -->
        <div class="text-center lg:text-left">
          <h1 class="text-4xl lg:text-5xl font-bold text-slate-900 mb-6">
            About <span class="gradient-text">Me</span>
          </h1>
          <p class="text-xl text-slate-600 mb-6 max-w-2xl">
            Arkadi Avanesyan is a world-class expert in Finance, Investment Banking, Technology, and Data Science.
          </p>
          <p class="text-lg text-slate-500 mb-8 max-w-2xl">
            Now a global corporate trainer, teaching modern tools and technologies in finance and data management,
            with clients including <strong class="text-slate-700">The World Bank</strong> and <strong class="text-slate-700">HSBC</strong>.
          </p>
          <a href="/files/Avanesyan.CV.2024.pdf" class="btn-primary" download>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Download Resume
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Education -->
  <section class="py-16 px-6 bg-white">
    <div class="max-w-4xl mx-auto">
      <h2 class="section-title">Education</h2>
      <div class="space-y-6">
        <div class="card flex items-start gap-4">
          <div class="w-12 h-12 rounded-xl bg-blue-100 flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path d="M12 14l9-5-9-5-9 5 9 5z" />
              <path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-slate-900 text-lg">MSc in Quantitative Finance</h3>
            <p class="text-slate-500">Solvay Brussels School of Economics and Management</p>
          </div>
        </div>

        <div class="card flex items-start gap-4">
          <div class="w-12 h-12 rounded-xl bg-cyan-100 flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-cyan-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-slate-900 text-lg">BSc in Business Engineering</h3>
            <p class="text-slate-500">Free University of Brussels</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Current Projects -->
  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="section-title">Current Projects</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="card text-center">
          <div class="w-14 h-14 rounded-2xl bg-purple-100 flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="font-semibold text-slate-900 mb-2">Content Creator</h3>
          <p class="text-slate-500 text-sm">Udemy, Starweaver, Coursera</p>
        </div>

        <a href="https://longspeakadvisory.com/" target="_blank" rel="noopener noreferrer" class="card text-center group hover:border-green-200">
          <div class="w-14 h-14 rounded-2xl bg-green-100 flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform">
            <svg class="w-7 h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </div>
          <h3 class="font-semibold text-slate-900 mb-2">Software Consultant</h3>
          <p class="text-slate-500 text-sm">Longs Peak Advisory</p>
        </a>

        <a href="https://smartpayroll.ch/" target="_blank" rel="noopener noreferrer" class="card text-center group hover:border-orange-200">
          <div class="w-14 h-14 rounded-2xl bg-orange-100 flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform">
            <svg class="w-7 h-7 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="font-semibold text-slate-900 mb-2">Lead Developer</h3>
          <p class="text-slate-500 text-sm">smart payroll</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="py-20 px-6 bg-slate-900">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Let's Connect</h2>
      <p class="text-slate-400 mb-8 max-w-xl mx-auto">
        Have a project in mind or interested in training? I'd love to hear from you.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href="mailto:aavanesy@outlook.com"
          class="inline-flex items-center gap-2 px-6 py-3 bg-blue-600 text-white font-medium rounded-full hover:bg-blue-700 transition-all"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          Email Me
        </a>
        <a
          href="https://www.linkedin.com/in/arkadiavan/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 bg-slate-800 text-white font-medium rounded-full hover:bg-slate-700 transition-all"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
      </div>
    </div>
  </section>
</Layout>
