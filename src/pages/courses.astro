---
import Layout from "../layouts/Layout.astro";

const udemyCourses = [
  {
    title: "Programming Automation with R and RStudio - Complete Guide",
    url: "https://www.udemy.com/course/complete-guide-to-automation-with-r-in-2021/?referralCode=39E8E56D2D13D75FE9DF",
    description: "Automate repetitive tasks with R and RStudio",
  },
  {
    title: "ChatGPT & Copilot for Python & R Data Science Projects",
    url: "https://www.udemy.com/course/ai-powered-data-science-projects-with-chatgpt-copilot/?referralCode=3E554B3C7C3E5859C201",
    description: "Use ChatGPT and Copilot in real data science projects",
  },
  {
    title: "Minimalist Framework to be Organized and Productive in Tech",
    url: "https://www.udemy.com/course/miminalist-framework-to-be-organized-and-productive-in-tech/?referralCode=F466AD2E75AB662FD278",
    description: "A simple system for staying organized in tech",
  },
];
---

<Layout title="Online Courses | Arkadi Avanesyan">
  <!-- Hero -->
  <section class="pt-32 pb-16 px-6">
    <div class="max-w-4xl mx-auto">
      <p class="text-accent tracking-[0.3em] text-xs mb-6 uppercase">Teaching</p>
      <h1 class="text-4xl lg:text-6xl font-bold text-text-primary mb-8 leading-tight">
        Online Courses
      </h1>
      <p class="text-xl text-text-secondary max-w-2xl leading-relaxed">
        80,000+ students across Coursera, Udemy, and Codementor.
      </p>
    </div>
  </section>

  <!-- Platform numbers -->
  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="grid md:grid-cols-3 gap-16">
        <a href="https://www.coursera.org/instructor/~139312072" target="_blank" rel="noopener noreferrer" class="group">
          <p class="text-text-muted text-xs uppercase tracking-widest mb-3">Coursera</p>
          <p class="text-5xl font-serif font-bold text-text-primary group-hover:text-accent transition-colors">70,000+</p>
          <p class="text-text-muted text-sm mt-2">students</p>
        </a>
        <a href="https://www.udemy.com/user/arkadi-10/" target="_blank" rel="noopener noreferrer" class="group">
          <p class="text-text-muted text-xs uppercase tracking-widest mb-3">Udemy</p>
          <p class="text-5xl font-serif font-bold text-text-primary group-hover:text-accent transition-colors">8,000+</p>
          <p class="text-text-muted text-sm mt-2">students</p>
        </a>
        <a href="https://www.codementor.io/@aavanesy" target="_blank" rel="noopener noreferrer" class="group">
          <p class="text-text-muted text-xs uppercase tracking-widest mb-3">Codementor</p>
          <p class="text-5xl font-serif font-bold text-text-primary group-hover:text-accent transition-colors">850+</p>
          <p class="text-text-muted text-sm mt-2">clients mentored</p>
        </a>
      </div>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-6"><div class="h-px bg-border"></div></div>

  <!-- Mentoring -->
  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <blockquote class="border-l-2 border-accent pl-8">
        <p class="text-text-secondary text-lg leading-relaxed italic">
          Through Codementor, I've mentored over 850 clients in data science, finance and programming,
          achieving a 4.99/5 rating and becoming a Featured Mentor for 10 consecutive months in 2020.
        </p>
      </blockquote>
    </div>
  </section>

  <!-- Udemy Courses -->
  <section class="green-section py-24 px-6">
    <div class="max-w-4xl mx-auto">
      <p class="text-accent tracking-[0.3em] text-xs mb-6 uppercase">Udemy</p>
      <h2 class="text-3xl font-bold mb-12">Course Catalog</h2>

      <div class="space-y-0 divide-y divide-[#2A5A3A]">
        {udemyCourses.map((course) => (
          <a
            href={course.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group block py-8 first:pt-0 last:pb-0"
          >
            <h3 class="font-semibold text-[#E8F0EA] group-hover:text-accent transition-colors mb-2 text-lg">
              {course.title}
            </h3>
            <p class="text-[#8BAE90] text-sm">{course.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-2xl font-bold text-text-primary mb-4">Need training for your team?</h2>
      <p class="text-text-secondary mb-8">
        I run custom programs for organizations in finance, data science, and automation.
      </p>
      <a href="/training" class="btn-primary">See corporate training</a>
    </div>
  </section>
</Layout>
